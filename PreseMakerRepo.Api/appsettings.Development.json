{
  "DatabaseProvider": "SQLite",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=presemaker-dev.db"
  },
  "Jwt": {
    "Issuer": "https://localhost",
    "Audience": "presemaker-repo-api",
    "SecretKey": "dev-secret-key-change-before-production-at-least-32-chars",
    "AccessTokenExpiryMinutes": 60,
    "RefreshTokenExpiryDays": 30
  },
  "Storage": {
    "RootPath": "dev-storage",
    "MaxModuleSizeBytes": 524288000,
    "MaxMaterialSizeBytes": 209715200,
    "LargeZipThresholdBytes": 104857600,
    "RetainRemovedFileDays": 30
  },
  "Email": {
    "SmtpHost": "localhost",
    "SmtpPort": 1025,
    "SmtpUseSsl": false,
    "SmtpUsername": "",
    "SmtpPassword": "",
    "FromAddress": "noreply@localhost",
    "FromDisplayName": "PreseMaker Repository (Dev)",
    "AdminAddress": "admin@localhost",
    "TemplatesPath": "EmailTemplates"
  },
  "Taxonomy": {
    "ConfigPath": "Data/Seed/taxonomy.json"
  },
  "AdminBootstrap": {
    "Email": "admin@localhost",
    "Username": "admin",
    "Password": "Admin123!"
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000", "https://localhost:3000" ]
  },
  "Logging": {
    "FilePath": "logs/app-.log",
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft": "Information",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
      }
    }
  }
}
