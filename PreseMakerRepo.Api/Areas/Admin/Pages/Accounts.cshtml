@page "/admin/accounts"
@model PreseMakerRepo.Api.Areas.Admin.Pages.AccountsModel
@{ ViewData["Title"] = "Accounts"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h4 mb-0">Accounts</h1>
    <form method="get" class="d-flex gap-2">
        <input type="search" name="q" value="@Model.Q" class="form-control form-control-sm" placeholder="Search username or email…" style="width:220px" />
        <button type="submit" class="btn btn-outline-secondary btn-sm">Search</button>
    </form>
</div>

<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Username</th><th>Email</th><th>Registered</th><th>Role</th><th>Status</th><th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var a in Model.Accounts)
            {
                <tr>
                    <td>@a.Username</td>
                    <td class="small text-muted">@a.Email</td>
                    <td class="small text-muted">@a.RegisteredUtc.ToString("MMM d, yyyy")</td>
                    <td>
                        @if (a.IsAdmin)
                        {
                            <span class="badge bg-primary">Administrator</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Contributor</span>
                        }
                    </td>
                    <td>
                        @if (a.IsSuspended)
                        {
                            <span class="badge bg-danger">Suspended</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Active</span>
                        }
                    </td>
                    <td>
                        @if (a.IsAdmin)
                        {
                            @if (a.Id == Model.CurrentUserId)
                            {
                                <span class="text-muted small">(you)</span>
                            }
                            else
                            {
                                <form method="post" asp-page-handler="Demote" class="d-inline">
                                    <input type="hidden" name="id" value="@a.Id" />
                                    <button type="submit" class="btn btn-outline-danger btn-sm"
                                            onclick="return confirm('Remove Administrator role from this user?')">Remove Admin</button>
                                </form>
                            }
                        }
                        else
                        {
                            <form method="post" asp-page-handler="Promote" class="d-inline">
                                <input type="hidden" name="id" value="@a.Id" />
                                <button type="submit" class="btn btn-outline-primary btn-sm"
                                        onclick="return confirm('Promote this user to Administrator?')">Make Admin</button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
