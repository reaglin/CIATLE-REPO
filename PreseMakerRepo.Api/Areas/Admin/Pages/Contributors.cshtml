@page "/admin/contributors"
@model PreseMakerRepo.Api.Areas.Admin.Pages.ContributorsModel
@{ ViewData["Title"] = "Contributors"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h4 mb-0">Contributors</h1>
    <form method="get" class="d-flex gap-2">
        <input type="search" name="q" value="@Model.Q" class="form-control form-control-sm" placeholder="Search username or email…" style="width:220px" />
        <button type="submit" class="btn btn-outline-secondary btn-sm">Search</button>
    </form>
</div>

<div class="table-responsive">
    <table class="table table-sm table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Username</th><th>Institution</th><th>Registered</th>
                <th>Modules</th><th>Materials</th><th>Status</th><th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var u in Model.Contributors)
            {
                <tr class="@(u.IsSuspended ? "table-danger" : "")">
                    <td>
                        @u.Username
                        @if (u.IsEduVerified) { <span class="badge badge-edu ms-1">EDU</span> }
                    </td>
                    <td class="small text-muted">@u.InstitutionName</td>
                    <td class="small text-muted">@u.RegisteredUtc.ToString("MMM d, yyyy")</td>
                    <td>@u.ModuleCount</td>
                    <td>@u.MaterialCount</td>
                    <td>
                        @if (u.IsSuspended)
                        {
                            <span class="badge bg-danger">Suspended</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Active</span>
                        }
                    </td>
                    <td>
                        <div class="d-flex gap-1">
                            @if (u.IsSuspended)
                            {
                                <form method="post" asp-page-handler="Reinstate">
                                    <input type="hidden" name="id" value="@u.Id" />
                                    <button type="submit" class="btn btn-success btn-sm">Reinstate</button>
                                </form>
                            }
                            else
                            {
                                <button type="button" class="btn btn-warning btn-sm"
                                        data-bs-toggle="modal" data-bs-target="#suspendModal"
                                        data-id="@u.Id" data-username="@u.Username">Suspend</button>
                            }
                            <button type="button" class="btn btn-outline-secondary btn-sm"
                                    data-bs-toggle="modal" data-bs-target="#contactModal"
                                    data-id="@u.Id" data-username="@u.Username">Contact</button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Suspend Modal -->
<div class="modal fade" id="suspendModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">Suspend Contributor</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <form method="post" asp-page-handler="Suspend" id="suspendForm">
                <input type="hidden" name="id" id="suspendId" />
                <div class="modal-body">
                    <p>Suspending: <strong id="suspendUsername"></strong></p>
                    <div class="mb-3">
                        <label class="form-label">Reason</label>
                        <textarea name="reason" class="form-control" rows="3" required></textarea>
                    </div>
                    <div class="form-check">
                        <input type="checkbox" name="notify" value="true" class="form-check-input" id="suspendNotify" checked />
                        <label class="form-check-label" for="suspendNotify">Notify contributor by email</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-warning">Suspend</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Contact Modal -->
<div class="modal fade" id="contactModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header"><h5 class="modal-title">Contact Contributor</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div>
            <form method="post" asp-page-handler="Contact">
                <input type="hidden" name="id" id="contactId" />
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Subject</label>
                        <input type="text" name="subject" class="form-control" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Message</label>
                        <textarea name="body" class="form-control" rows="4" required></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Send Email</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.getElementById('suspendModal').addEventListener('show.bs.modal', function(e) {
    document.getElementById('suspendId').value = e.relatedTarget.dataset.id;
    document.getElementById('suspendUsername').textContent = e.relatedTarget.dataset.username;
});
document.getElementById('contactModal').addEventListener('show.bs.modal', function(e) {
    document.getElementById('contactId').value = e.relatedTarget.dataset.id;
});
</script>
}
