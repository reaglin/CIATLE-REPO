@page "/browse/subdisciplines"
@model PreseMakerRepo.Api.Pages.Browse.AllLevel2Model
@{ ViewData["Title"] = "Browse by " + Model.Level2Label; }

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Browse/Index">Browse</a></li>
        <li class="breadcrumb-item active">Browse by @Model.Level2Label</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-1">
    <h1 class="h4 mb-0">Browse by @Model.Level2Label</h1>
    <span class="text-muted small">@Model.TotalCount entries</span>
</div>
<p class="text-muted small mb-4">Alphabetical listing of all @Model.Level2Label.ToLower() areas. Click any entry to browse its courses.</p>

@if (!Model.Items.Any())
{
    <div class="alert alert-info">No entries found.</div>
}
else
{
    <div class="list-group list-group-flush mb-4">
        @foreach (var item in Model.Items)
        {
            <a asp-page="/Browse/Level2"
               asp-route-level1Key="@item.Level1Key"
               asp-route-level2Key="@item.Key"
               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-2">
                <div>
                    <span class="fw-medium">@item.Name</span>
                    <span class="text-muted small ms-2">(@item.Key)</span>
                    <span class="text-muted small ms-2">— @item.Level1Name</span>
                </div>
                <div class="text-muted small text-end text-nowrap ms-3">
                    @if (item.CourseCount > 0)
                    {
                        <span>@item.CourseCount course@(item.CourseCount != 1 ? "s" : "")</span>
                        @if (item.ModuleCount > 0)
                        {
                            <span class="mx-1">·</span>
                            <span>@item.ModuleCount module@(item.ModuleCount != 1 ? "s" : "")</span>
                        }
                    }
                    else
                    {
                        <span class="text-muted">no content yet</span>
                    }
                </div>
            </a>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm justify-content-center">
                <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                    <a class="page-link" asp-page="/Browse/AllLevel2" asp-route-page="@(Model.Page - 1)">Previous</a>
                </li>
                @for (int p = 1; p <= Model.TotalPages; p++)
                {
                    <li class="page-item @(p == Model.Page ? "active" : "")">
                        <a class="page-link" asp-page="/Browse/AllLevel2" asp-route-page="@p">@p</a>
                    </li>
                }
                <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                    <a class="page-link" asp-page="/Browse/AllLevel2" asp-route-page="@(Model.Page + 1)">Next</a>
                </li>
            </ul>
        </nav>
    }
}
