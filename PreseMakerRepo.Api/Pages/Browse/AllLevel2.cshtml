@page "/browse/subdisciplines"
@model PreseMakerRepo.Api.Pages.Browse.AllLevel2Model
@{ ViewData["Title"] = "Browse by " + Model.Level2Label; }

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Browse/Index">Browse</a></li>
        <li class="breadcrumb-item active">Browse by @Model.Level2Label</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-center mb-1">
    <h1 class="h4 mb-0">Browse by @Model.Level2Label</h1>
    <span class="text-muted small">@Model.TotalCount total</span>
</div>
<p class="text-muted small mb-3">Select a letter to browse prefixes. Click any entry to browse its courses.</p>

@* ── Letter navigation ── *@
<div class="d-flex flex-wrap gap-1 mb-4" role="navigation" aria-label="Alphabetic filter">
    @foreach (char c in "ABCDEFGHIJKLMNOPQRSTUVWXYZ")
    {
        bool available = Model.AvailableLetters.Contains(c);
        bool active    = Model.SelectedLetter == c.ToString();

        if (available)
        {
            <a asp-page="/Browse/AllLevel2"
               asp-route-letter="@c"
               class="btn btn-sm @(active ? "btn-primary" : "btn-outline-secondary")"
               style="min-width:2.2rem">@c</a>
        }
        else
        {
            <span class="btn btn-sm btn-outline-secondary disabled"
                  style="min-width:2.2rem;opacity:.3">@c</span>
        }
    }
</div>

@if (!Model.Items.Any())
{
    <div class="alert alert-info">No entries found for the letter @Model.SelectedLetter.</div>
}
else
{
    <div class="list-group list-group-flush mb-4">
        @foreach (var item in Model.Items)
        {
            <a asp-page="/Browse/Level2"
               asp-route-level1Key="@item.Level1Key"
               asp-route-level2Key="@item.Key"
               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center py-2">
                <span>
                    <span class="fw-bold">@item.Key</span>
                    <span class="text-muted mx-1">—</span>
                    <span>@item.Name</span>
                </span>
                @if (item.CourseCount > 0)
                {
                    <span class="text-muted small text-nowrap ms-3">
                        @item.CourseCount course@(item.CourseCount != 1 ? "s" : "")
                        @if (item.ModuleCount > 0)
                        {
                            <span class="mx-1">·</span>
                            @item.ModuleCount <text>module@(item.ModuleCount != 1 ? "s" : "")</text>
                        }
                    </span>
                }
                else
                {
                    <span class="text-muted small ms-3">no content yet</span>
                }
            </a>
        }
    </div>
}
