@page "/browse/{level1Key}"
@model PreseMakerRepo.Api.Pages.Browse.Level1Model
@{ ViewData["Title"] = Model.Discipline?.Name ?? "Browse"; }

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Browse/Index">Browse</a></li>
        <li class="breadcrumb-item active">@Model.Discipline?.Name</li>
    </ol>
</nav>

<h1 class="h4 mb-1">@Model.Discipline?.Name</h1>
<p class="text-muted mb-4">
    @Model.Discipline?.CourseCount course@(Model.Discipline?.CourseCount != 1 ? "s" : "")
    · @Model.Discipline?.ModuleCount module@(Model.Discipline?.ModuleCount != 1 ? "s" : "")
</p>

<div class="row row-cols-2 row-cols-md-3 g-3 taxonomy-grid">
    @foreach (var node in Model.Children)
    {
        <div class="col">
            <a asp-page="/Browse/Level2"
               asp-route-level1Key="@Model.Level1Key"
               asp-route-level2Key="@node.Key"
               class="card h-100 taxonomy-card">
                <div class="card-body">
                    <h6 class="card-title mb-1">@node.Key — @node.Name</h6>
                    <p class="card-text text-muted small mb-0">
                        @node.CourseCount course@(node.CourseCount != 1 ? "s" : "")
                        · @node.ModuleCount module@(node.ModuleCount != 1 ? "s" : "")
                    </p>
                </div>
            </a>
        </div>
    }
</div>
