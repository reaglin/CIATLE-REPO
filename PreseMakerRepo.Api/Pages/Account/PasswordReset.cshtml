@page "/account/password-reset"
@model PreseMakerRepo.Api.Pages.Account.PasswordResetModel
@{ ViewData["Title"] = "Password Reset"; }

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <h1 class="h4 mb-4">@(Model.IsConfirmMode ? "Set New Password" : "Reset Password")</h1>

        @if (Model.ErrorMessage is not null)
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        @if (!Model.IsConfirmMode)
        {
            <p class="text-muted">Enter your email address and we'll send you a reset link.</p>
            <form method="post" asp-page-handler="Request">
                <div class="mb-3">
                    <label for="RequestEmail" class="form-label">Email address</label>
                    <input id="RequestEmail" asp-for="RequestEmail" type="email" class="form-control" required />
                </div>
                <button type="submit" class="btn btn-primary w-100">Send Reset Link</button>
            </form>
        }
        else
        {
            <form method="post" asp-page-handler="Confirm">
                <input type="hidden" asp-for="ConfirmToken" />
                <input type="hidden" asp-for="ConfirmEmail" />
                <div class="mb-3">
                    <label for="NewPassword" class="form-label">New Password</label>
                    <input id="NewPassword" asp-for="NewPassword" type="password" class="form-control" required />
                </div>
                <div class="mb-4">
                    <label for="ConfirmPassword" class="form-label">Confirm Password</label>
                    <input id="ConfirmPassword" asp-for="ConfirmPassword" type="password" class="form-control" required />
                </div>
                <button type="submit" class="btn btn-primary w-100">Reset Password</button>
            </form>
        }

        <p class="text-center mt-3 small"><a asp-page="/Account/Login">Back to Log In</a></p>
    </div>
</div>
