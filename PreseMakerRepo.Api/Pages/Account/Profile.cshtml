@page "/account/profile"
@model PreseMakerRepo.Api.Pages.Account.ProfileModel
@{ ViewData["Title"] = "My Profile"; }

@if (Model.Contributor is null) { return; }
@{ var u = Model.Contributor; }

<h1 class="h4 mb-4">My Profile</h1>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Username</dt>
                    <dd class="col-sm-8">@u.UserName</dd>

                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">
                        @u.Email
                        @if (!u.EmailConfirmed) { <span class="badge bg-warning text-dark ms-1">Unconfirmed</span> }
                    </dd>

                    @if (!string.IsNullOrEmpty(u.DisplayName) && u.DisplayName != u.UserName)
                    {
                        <dt class="col-sm-4">Display Name</dt>
                        <dd class="col-sm-8">@u.DisplayName</dd>
                    }

                    <dt class="col-sm-4">Institution</dt>
                    <dd class="col-sm-8">
                        @if (!string.IsNullOrEmpty(u.InstitutionName))
                        {
                            @u.InstitutionName
                            @if (u.IsEduVerified) { <span class="badge badge-edu ms-1">EDU Verified</span> }
                        }
                        else
                        {
                            <span class="text-muted">—</span>
                        }
                    </dd>

                    <dt class="col-sm-4">Member since</dt>
                    <dd class="col-sm-8">@u.RegisteredUtc.ToString("MMMM d, yyyy")</dd>
                </dl>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-body">
                <h6 class="card-title">Quick Links</h6>
                <a asp-page="/Account/MySubmissions" class="btn btn-outline-primary btn-sm w-100 mb-2">My Submissions</a>
                <a asp-page="/Account/PasswordReset" class="btn btn-outline-secondary btn-sm w-100">Change Password</a>
            </div>
        </div>
    </div>
</div>
