@page "/account/login"
@model PreseMakerRepo.Api.Pages.Account.LoginModel
@{ ViewData["Title"] = "Log In"; }

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <h1 class="h4 mb-4">Log In</h1>

        @if (Model.ErrorMessage is not null)
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }

        <form method="post">
            <input type="hidden" asp-for="ReturnUrl" />
            <div class="mb-3">
                <label for="Email" class="form-label">Email address</label>
                <input id="Email" asp-for="Email" type="email" class="form-control" autocomplete="email" required />
            </div>
            <div class="mb-3">
                <label for="Password" class="form-label">Password</label>
                <input id="Password" asp-for="Password" type="password" class="form-control" required />
            </div>
            <div class="mb-4 form-check">
                <input id="RememberMe" asp-for="RememberMe" type="checkbox" class="form-check-input" />
                <label for="RememberMe" class="form-check-label">Remember me</label>
            </div>
            <button type="submit" class="btn btn-primary w-100">Log In</button>
        </form>

        <div class="text-center mt-3 text-muted small">
            <a asp-page="/Account/PasswordReset">Forgot your password?</a>
            <span class="mx-2">·</span>
            <a asp-page="/Account/Register">Create account</a>
        </div>
    </div>
</div>
