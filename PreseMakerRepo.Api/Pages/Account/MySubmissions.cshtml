@page "/account/my-submissions"
@model PreseMakerRepo.Api.Pages.Account.MySubmissionsModel
@{ ViewData["Title"] = "My Submissions"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h4 mb-0">My Submissions</h1>
    <div class="btn-group btn-group-sm">
        <a asp-page="/Account/MySubmissions" asp-route-filter="all"
           class="btn @(Model.Filter == "all" ? "btn-primary" : "btn-outline-secondary")">All</a>
        <a asp-page="/Account/MySubmissions" asp-route-filter="module"
           class="btn @(Model.Filter == "module" ? "btn-primary" : "btn-outline-secondary")">Modules</a>
        <a asp-page="/Account/MySubmissions" asp-route-filter="material"
           class="btn @(Model.Filter == "material" ? "btn-primary" : "btn-outline-secondary")">Materials</a>
    </div>
</div>

@if (Model.Modules.Any())
{
    <h2 class="h6 text-muted mb-2">Modules</h2>
    <div class="list-group mb-4">
        @foreach (var m in Model.Modules)
        {
            var matCount = m.Materials.Count(mat => mat.Status == ContentStatus.Published);
            <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(m.Status == ContentStatus.Removed ? "opacity-50" : "")">
                <div>
                    @if (m.Status == ContentStatus.Published)
                    {
                        <a asp-page="/Module/Detail" asp-route-moduleId="@m.Id" class="fw-semibold text-decoration-none">@m.Title</a>
                    }
                    else
                    {
                        <span class="fw-semibold">@m.Title</span>
                    }
                    <div class="text-muted small">@m.CourseId · @matCount material@(matCount != 1 ? "s" : "") · @m.SubmittedUtc.ToString("MMM d, yyyy")</div>
                </div>
                <span class="badge @MySubmissionsModel.StatusBadge(m.Status)">@m.Status</span>
            </div>
        }
    </div>
}

@if (Model.Materials.Any())
{
    <h2 class="h6 text-muted mb-2">Materials</h2>
    <div class="list-group mb-4">
        @foreach (var mat in Model.Materials)
        {
            <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(mat.Status == ContentStatus.Removed ? "opacity-50" : "")">
                <div>
                    @if (mat.Status == ContentStatus.Published)
                    {
                        <a asp-page="/Material/Detail" asp-route-materialId="@mat.Id" class="fw-semibold text-decoration-none">@mat.Title</a>
                    }
                    else
                    {
                        <span class="fw-semibold">@mat.Title</span>
                    }
                    <div class="text-muted small">
                        <span class="badge badge-material-type me-1">@mat.Type</span>
                        in @mat.Module.Title · @mat.SubmittedUtc.ToString("MMM d, yyyy")
                    </div>
                </div>
                <span class="badge @MySubmissionsModel.StatusBadge(mat.Status)">@mat.Status</span>
            </div>
        }
    </div>
}

@if (!Model.Modules.Any() && !Model.Materials.Any())
{
    <div class="alert alert-info">You have no submissions yet.</div>
}
