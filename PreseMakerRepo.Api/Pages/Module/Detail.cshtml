@page "/modules/{moduleId:guid}"
@model PreseMakerRepo.Api.Pages.Module.DetailModel
@{ ViewData["Title"] = Model.Module?.Title; }

@if (Model.Module is null) { return; }
@{
    var m = Model.Module;
    var courseId = m.CourseId;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-page="/Browse/Course" asp-route-courseId="@courseId">@courseId</a></li>
        <li class="breadcrumb-item active">@m.Title</li>
    </ol>
</nav>

<div class="row g-4">
    <div class="col-lg-8">
        <h1 class="h3 mb-1">@m.Title</h1>
        <p class="text-muted mb-3">@courseId · @m.Course?.Title</p>
        <p>@m.Description</p>

        @if (Model.Outcomes.Any())
        {
            <h2 class="h5 mt-4 mb-2">Learning Outcomes</h2>
            <ul>
                @foreach (var o in Model.Outcomes) { <li>@o</li> }
            </ul>
        }

        <h2 class="h5 mt-4 mb-3">Materials <span class="badge bg-secondary">@Model.Materials.Count</span></h2>
        @if (!Model.Materials.Any())
        {
            <p class="text-muted">No materials attached to this module.</p>
        }
        else
        {
            @foreach (var mat in Model.Materials)
            {
                <div class="card mb-2">
                    <div class="card-body py-2 px-3 d-flex align-items-center justify-content-between">
                        <div>
                            <a asp-page="/Material/Detail" asp-route-materialId="@mat.Id" class="fw-semibold text-decoration-none">@mat.Title</a>
                            <span class="badge badge-material-type ms-2">@mat.Type</span>
                            <small class="text-muted ms-2">@mat.FileName · @FormatSize(mat.FileSizeBytes)</small>
                        </div>
                        <a href="@Model.MaterialDownloadUrl(mat.Id)" class="btn btn-outline-primary btn-sm">Download</a>
                    </div>
                </div>
            }
        }
    </div>

    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-body">
                <h6 class="card-title">Contributor</h6>
                <p class="mb-1 fw-semibold">
                    @m.Contributor.UserName
                    @if (m.Contributor.IsEduVerified) { <span class="badge badge-edu ms-1">EDU</span> }
                </p>
                @if (!string.IsNullOrEmpty(m.Contributor.InstitutionName))
                {
                    <p class="text-muted small mb-0">@m.Contributor.InstitutionName</p>
                }
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-body">
                <h6 class="card-title">License</h6>
                <a href="@Model.LicenseUrl" target="_blank" rel="noopener"
                   class="badge @Model.LicenseBadgeClass text-decoration-none">@Model.LicenseDisplayName</a>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-body">
                <h6 class="card-title">Downloads</h6>
                <a href="@Model.DownloadUrl" class="btn btn-primary btn-sm w-100">Download All (ZIP)</a>
            </div>
        </div>

        <div class="card mb-3">
            <div class="card-body">
                <h6 class="card-title">Submitted</h6>
                <p class="mb-0 small">@m.SubmittedUtc.ToString("MMMM d, yyyy")</p>
                @if (m.UpdatedUtc.HasValue)
                {
                    <p class="mb-0 small text-muted">Updated @m.UpdatedUtc.Value.ToString("MMMM d, yyyy")</p>
                }
            </div>
        </div>

        <button class="btn btn-outline-danger btn-sm w-100"
                data-bs-toggle="modal" data-bs-target="#reportModal">
            Report This Module
        </button>
    </div>
</div>

<!-- Report Modal -->
<div class="modal fade" id="reportModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Report Module</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small">This will flag the module for administrator review. The content remains visible until reviewed.</p>
                <form id="reportForm" data-endpoint="@Model.ReportEndpoint">
                    <label for="reportReason" class="form-label">Reason (optional)</label>
                    <textarea id="reportReason" class="form-control" rows="3" maxlength="500"
                              placeholder="Describe the issue…"></textarea>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="reportSubmitBtn" class="btn btn-danger">Submit Report</button>
            </div>
        </div>
    </div>
</div>

@functions {
    static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:F1} KB";
        return $"{bytes / (1024.0 * 1024):F1} MB";
    }
}
