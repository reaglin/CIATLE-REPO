@page
@model IndexModel
@{ ViewData["Title"] = "Home"; }

<div class="py-4 text-center">
    <h1 class="display-6 fw-bold">Florida Course Repo</h1>
    <p class="lead text-muted">Open educational resources for Florida college courses</p>
    <form class="d-flex justify-content-center mt-3" method="get" asp-page="/Browse/Index">
        <div class="input-group" style="max-width:560px">
            <input type="search" name="q" class="form-control form-control-lg"
                   placeholder="Search modules, materials, or course IDs…" />
            <button type="submit" class="btn btn-primary btn-lg">Search</button>
        </div>
    </form>
</div>

<hr />

@if (Model.RecentModules.Any())
{
    <section class="mb-5">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h5 mb-0">Recently Added</h2>
            <a asp-page="/Browse/Index" class="btn btn-outline-secondary btn-sm">Browse All</a>
        </div>
        <div class="row row-cols-1 row-cols-md-2 g-3">
            @foreach (var m in Model.RecentModules)
            {
                <div class="col">
                    <div class="card h-100 content-card">
                        <div class="card-body">
                            <h6 class="card-title mb-1">
                                <a asp-page="/Module/Detail" asp-route-moduleId="@m.Id" class="stretched-link text-decoration-none">@m.Title</a>
                            </h6>
                            <div class="text-muted small">
                                @m.CourseId
                                @if (m.Contributor is not null)
                                {
                                    <span class="ms-2">· @m.Contributor.UserName</span>
                                    @if (m.Contributor.IsEduVerified)
                                    {
                                        <span class="badge badge-edu ms-1">EDU</span>
                                    }
                                }
                            </div>
                        </div>
                        <div class="card-footer text-muted small">
                            Added @m.SubmittedUtc.ToString("MMM d, yyyy")
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>
}

<section>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h5 mb-0">Browse by Discipline</h2>
        <a asp-page="/Browse/AllLevel2" class="btn btn-outline-secondary btn-sm">Browse by @Model.Level2Label</a>
    </div>
    <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-3 taxonomy-grid">
        @foreach (var node in Model.Disciplines)
        {
            <div class="col">
                <a asp-page="/Browse/Level1" asp-route-level1Key="@node.Key"
                   class="card h-100 taxonomy-card">
                    <div class="card-body">
                        <h6 class="card-title mb-1">@node.Name</h6>
                        <p class="card-text text-muted small mb-0">
                            @node.CourseCount course@(node.CourseCount != 1 ? "s" : "")
                            · @node.ModuleCount module@(node.ModuleCount != 1 ? "s" : "")
                        </p>
                    </div>
                </a>
            </div>
        }
    </div>
</section>
